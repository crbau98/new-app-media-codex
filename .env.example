# ─── Core ───────────────────────────────────────────────────────────────────
APP_NAME="Codex Research Radar"
ENVIRONMENT=development          # set to "production" on a live server
PORT=8080                        # Docker only — local dev uses uvicorn default 8000

# ─── Database & storage ──────────────────────────────────────────────────────
# DATABASE_PATH=./data/research.db     # leave blank to use default
# IMAGE_DIR=./data/images              # leave blank to use default

# ─── Crawl schedule ──────────────────────────────────────────────────────────
CRAWL_INTERVAL_MINUTES=180
PER_QUERY_LIMIT=5
RUN_STARTUP_CRAWL=false

# ─── AI / hypothesis generation ──────────────────────────────────────────────
# Without a key the app uses the built-in deterministic hypothesis generator.
# Any OpenAI-compatible API works (OpenAI, Groq, Together, Ollama, etc.)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Source-specific tokens (all optional) ───────────────────────────────────
# X (Twitter) — official API gives better results; falls back to indexed scrape
X_BEARER_TOKEN=

# PubMed API key (optional — raises rate limits)
# PUBMED_API_KEY=

# Firecrawl (optional web scraping backend)
# FIRECRAWL_API_KEY=

# ─── Per-source result limits ─────────────────────────────────────────────────
REDDIT_RESULTS=4
X_RESULTS=4
LPSG_RESULTS=4
COOMER_RESULTS=4
KEMONO_RESULTS=4
MALE_VIDEO_ARCHIVER_RESULTS=6
PUBMED_RESULTS=6
BIORXIV_RESULTS=4
ARXIV_RESULTS=4
FIRECRAWL_RESULTS=5
ANECDOTE_RESULTS=6
IMAGE_RESULTS=8

# ─── Outbound residential proxy for coomer / kemono video fetches ───────────
# coomer.st / kemono.* file shards (n*.coomer.st, n*.kemono.cr) block most
# datacenter IP ranges, so coomer VIDEO downloads (mp4/webm) fail on Render/
# Vercel without an upstream proxy. Set this to any residential or clean-DC
# HTTP/SOCKS5 proxy and the app will route coomer/kemono fetches through it.
# Leave unset to skip — images already work via img.coomer.st/thumbnail/*.
#
# Format:   http://user:pass@host:port        (supports http, https, socks5h)
# Examples (cheap services, paid by traffic):
#   Webshare residential:  http://user:pass@p.webshare.io:80
#   Bright Data:           http://brd-customer-xxx-zone-residential:pass@brd.superproxy.io:22225
#   IPRoyal:               http://user:pass@geo.iproyal.com:12321
# ARCHIVER_PROXY_URL=
# ARCHIVER_PROXY_HOSTS=coomer.st,coomer.su,kemono.su,kemono.party,kemono.cr
# ARCHIVER_PROXY_DISABLE_IMG=1     # skip proxy for img.* (they work without it)

# ─── Production-only ─────────────────────────────────────────────────────────
# Required when ENVIRONMENT=production (prevents accidental deployment)
# ADMIN_TOKEN=change-me

# Telegram channel scanning (MTProto via Pyrogram)
TELEGRAM_API_ID=37478698
TELEGRAM_API_HASH=de230ec6f07a43bf072590d128fc3c34
TELEGRAM_SESSION=           # generated by: python scripts/telegram_auth.py
TELEGRAM_SCAN_LIMIT=200
