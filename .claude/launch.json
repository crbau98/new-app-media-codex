{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI backend",
      "runtimeExecutable": "/usr/local/bin/python3.13",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Vite frontend",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["/usr/local/bin/npx", "vite", "--port", "5173"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "Vite worktree",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend-wt",
      "port": 5173
    },
    {
      "name": "Docker (production)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 8080
    }
  ]
}
